{
  "name": "@wklm/testing",
  "version": "2.0.0-beta.1",
  "description": "Mock Bluetooth API for testing @wklm apps — stateful devices, fake advertising, notification pump",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "AGENTS.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "bluetooth", "ble", "web-bluetooth", "webble", "testing", "mock",
    "jest", "vitest", "safari", "ios", "gatt", "polyfill", "navigator.bluetooth"
  ],
  "author": "wklm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/ioswebble-sdk.git",
    "directory": "packages/testing"
  },
  "homepage": "https://ioswebble.com/docs#testing-package",
  "bugs": {
    "url": "https://github.com/wklm/ioswebble-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "@types/web-bluetooth": "^0.0.21",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "ts-jest": "^29",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0"
  }
}
