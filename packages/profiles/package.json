{
  "name": "@wklm/profiles",
  "version": "1.0.0-beta.1",
  "description": "Pre-built BLE device profiles — heart rate, battery, device info. Typed parsers for Bluetooth GATT characteristics",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./heart-rate": {
      "types": "./dist/heart-rate.d.ts",
      "import": "./dist/heart-rate.mjs",
      "require": "./dist/heart-rate.js"
    },
    "./battery": {
      "types": "./dist/battery.d.ts",
      "import": "./dist/battery.mjs",
      "require": "./dist/battery.js"
    },
    "./device-info": {
      "types": "./dist/device-info.d.ts",
      "import": "./dist/device-info.mjs",
      "require": "./dist/device-info.js"
    }
  },
  "files": ["dist", "README.md", "AGENTS.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": ["bluetooth", "ble", "profiles", "heart-rate", "battery", "webble", "gatt", "device-info", "web-bluetooth", "ios", "safari", "ai", "agent", "polyfill", "navigator.bluetooth", "cross-browser"],
  "author": "wklm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/ioswebble-sdk.git",
    "directory": "packages/profiles"
  },
  "homepage": "https://ioswebble.com/docs#profiles-package",
  "bugs": {
    "url": "https://github.com/wklm/ioswebble-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@wklm/core": "^1.0.0-beta.1"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "@wklm/core": "^1.0.0-beta.1",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "ts-jest": "^29",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0"
  }
}
