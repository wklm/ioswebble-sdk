{
  "name": "@ios-web-bluetooth/react",
  "version": "2.0.0-beta.2",
  "description": "React hooks for Bluetooth Low Energy — useDevice, useScan, useProfile. Real-time BLE data in React",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "type-check": "npm run typecheck",
    "lint": "eslint src/**/*.{ts,tsx}",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@ios-web-bluetooth/core": ">=2.0.0-beta.2"
  },
  "peerDependencies": {
    "@ios-web-bluetooth/detect": ">=0.1.0",
    "@ios-web-bluetooth/profiles": ">=1.0.0-beta.2",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "@ios-web-bluetooth/detect": {
      "optional": true
    },
    "@ios-web-bluetooth/profiles": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ts-jest": "^29.4.9",
    "tslib": "^2.6.2",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "bluetooth",
    "ble",
    "webbluetooth",
    "web-bluetooth",
    "react",
    "react-hooks",
    "safari",
    "webble",
    "ios",
    "gatt",
    "bluetooth-low-energy",
    "ai",
    "agent",
    "mcp",
    "polyfill",
    "cross-browser",
    "web-bluetooth-polyfill",
    "safari-bluetooth",
    "navigator-bluetooth",
    "react-bluetooth"
  ],
  "author": "wklm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/ioswebble-sdk.git",
    "directory": "packages/react-sdk"
  },
  "bugs": {
    "url": "https://github.com/wklm/ioswebble-sdk/issues"
  },
  "homepage": "https://ioswebble.com/docs#react-sdk",
  "publishConfig": {
    "access": "public"
  }
}
