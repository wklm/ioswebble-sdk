{
  "name": "@ios-web-bluetooth/react",
  "version": "2.0.0-beta.2",
  "description": "React hooks for Bluetooth Low Energy — useDevice, useScan, useProfile. Real-time BLE data in React",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.{ts,tsx}",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@ios-web-bluetooth/core": ">=2.0.0-beta.2",
    "@ios-web-bluetooth/detect": ">=0.1.0",
    "@ios-web-bluetooth/profiles": ">=1.0.0-beta.2",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "@ios-web-bluetooth/detect": {
      "optional": true
    },
    "@ios-web-bluetooth/core": {
      "optional": true
    },
    "@ios-web-bluetooth/profiles": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.60.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "ts-jest": "^29.1.1",
    "tslib": "^2.6.2",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "bluetooth",
    "ble",
    "webbluetooth",
    "web-bluetooth",
    "react",
    "react-hooks",
    "safari",
    "webble",
    "ios",
    "gatt",
    "bluetooth-low-energy",
    "ai",
    "agent",
    "mcp",
    "polyfill",
    "cross-browser",
    "web-bluetooth-polyfill",
    "safari-bluetooth",
    "navigator-bluetooth",
    "react-bluetooth"
  ],
  "author": "wklm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/ioswebble-sdk.git",
    "directory": "packages/react-sdk"
  },
  "bugs": {
    "url": "https://github.com/wklm/ioswebble-sdk/issues"
  },
  "homepage": "https://ioswebble.com/docs#react-sdk",
  "publishConfig": {
    "access": "public"
  }
}
