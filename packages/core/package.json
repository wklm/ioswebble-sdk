{
  "name": "@wklm/core",
  "version": "1.0.0-beta.1",
  "description": "Web Bluetooth SDK — scan, connect, read/write BLE devices from iOS Safari",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "AGENTS.md", "CONTEXT.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": ["bluetooth", "ble", "web-bluetooth", "webble", "safari", "sdk", "ios", "gatt", "bluetooth-low-energy", "ai", "agent", "mcp"],
  "author": "wklm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/ioswebble-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://ioswebble.com/docs#core-package",
  "bugs": {
    "url": "https://github.com/wklm/ioswebble-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "ts-jest": "^29",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0"
  }
}
