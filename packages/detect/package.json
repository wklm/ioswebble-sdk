{
  "name": "@ios-web-bluetooth/detect",
  "version": "0.1.1",
  "description": "Detect WebBLE Safari extension on iOS. Auto-show install banner when extension not found",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./auto": {
      "import": "./dist/auto.mjs",
      "require": "./dist/auto.js"
    },
    "./react": {
      "import": "./dist/react.mjs",
      "require": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "AGENTS.md", "SKILL.md", "CONTEXT.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": ["ios", "safari", "bluetooth", "ble", "web-bluetooth", "webbluetooth", "webble", "extension", "detect", "install-banner", "ai", "agent", "mcp", "polyfill", "cross-browser", "safari-bluetooth", "navigator-bluetooth"],
  "author": "wklm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/ioswebble-sdk.git",
    "directory": "packages/detect"
  },
  "homepage": "https://ioswebble.com/docs#detect-package",
  "bugs": {
    "url": "https://github.com/wklm/ioswebble-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0"
  }
}
